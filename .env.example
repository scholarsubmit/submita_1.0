# ==================== SECURITY ====================
SECRET_KEY=your-secret-key-here-change-in-production
SESSION_SECURE=False

# ==================== DATABASE ====================
# For SQLite (development):
DATABASE_URL=sqlite:///submita.db

# For PostgreSQL (production):
DATABASE_URL=postgresql://username:password@localhost:5432/submita

# ==================== EMAIL - Google SMTP ====================
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=465
MAIL_USE_SSL=True
MAIL_USE_TLS=False
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password_here
MAIL_DEFAULT_SENDER=Submita <your_email@gmail.com>
MAIL_SENDER_NAME=Submita
USE_SMTP=true

# ==================== BREVO (Alternative) ====================
# USE_SMTP=false
# BREVO_API_KEY=your_brevo_api_key

# ==================== APP SETTINGS ====================
BASE_URL=https://submita.onrender.com
PRODUCTION=False
RENDER=False

# ==================== NETWORK SETTINGS ====================
HOST=0.0.0.0
PORT=5000
DEBUG=False

# ==================== BCRYPT ====================
BCRYPT_LOG_ROUNDS=12

# ==================== SESSION SETTINGS ====================
SESSION_COOKIE_SECURE=False
SESSION_COOKIE_SAMESITE=Lax
REMEMBER_COOKIE_SECURE=False
REMEMBER_COOKIE_SAMESITE=Lax

# ==================== SILENCE WARNINGS ====================
SQLALCHEMY_SILENCE_UBER_WARNING=1